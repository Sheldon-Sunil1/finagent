
# FinAgent — Phase 1 (Day 1-2) — Environment Example
# Generated: 2025-08-21 14:31

# Supabase project URL and keys (find in Project Settings -> API).
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Backend should use service role key on server-side only (NEVER expose in frontend).
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional: logging
LOG_LEVEL=INFO
